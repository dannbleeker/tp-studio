{
  "$schema": "https://claude.com/schemas/settings.json",
  "permissions": {
    "allow": [
      "Bash(git push:*)",
      "Bash(git push origin main:*)",
      "Bash(gh run watch:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build)",
      "Bash(node ./node_modules/vitest/vitest.mjs:*)",
      "Bash(node ./node_modules/typescript/bin/tsc:*)"
    ]
  },
  "autoMode": {
    "environment": ["$defaults"],
    "allow": [
      "$defaults",
      "TP Studio is a single-developer project with no PR review process. Direct pushes to origin/main are the standard workflow — Dann reviews changes in-session before authorizing each push and the CI on main is the gate. Treat `git push` / `git push origin main` as authorized when Dann has confirmed in chat (e.g. 'push', 'yes push', 'push to origin/main'). Do not soft-block on the default-branch concern."
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-bash-gate.cjs",
            "timeout": 60000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-bash-watch-ci.cjs",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
