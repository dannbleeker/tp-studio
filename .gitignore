node_modules
dist
coverage
# Transient stdout/stderr dumps from manual `vitest` / `tsc` runs (we
# captured these to a file during early sessions to work around
# Windows PowerShell quirks; they're never part of the build).
vitest-output.txt
tsc-output.txt
# Playwright e2e — `playwright-report` is the HTML report from the last
# run; `test-results` carries screenshots / videos / traces from failures.
playwright-report
test-results
# Storybook static export (Session 81). Generated by
# `pnpm build-storybook`; the dev-mode server (`pnpm storybook`)
# doesn't write to disk so only the built site needs ignoring.
storybook-static
.DS_Store
*.log
.vite
.env
.env.local
.idea
.vscode

# TypeScript build artifacts. The root tsconfig has `noEmit: true`, but
# `tsc -b` walks project references and the referenced `tsconfig.node.json`
# (composite: true) can incidentally emit alongside `src/` TS sources when
# invoked from this directory. Keep the source tree clean.
*.tsbuildinfo
src/**/*.d.ts
!src/vite-env.d.ts
src/domain/types.js
src/domain/tokens.js

# Session 106 — perf trace artifact (run via .github/workflows/perf-trace.yml)
perf-trace-output/

# Session 111 — generated in-app docs bundle. The book PDF, NOTICE, SECURITY,
# and USER_GUIDE are rendered into `public/` by `scripts/build-docs-bundle.mjs`
# (wired as the `prebuild` npm script) so Vite ships them at the branded
# subdomain instead of users having to follow GitHub links. Sources of truth
# are committed (the markdown files at repo root + the PDF under docs/guide);
# the generated copies in public/ are NOT.
public/Causal-Thinking-with-TP-Studio.pdf
public/notices.html
public/security.html
public/user-guide.html

# Session 114 — bundle-composition treemap emitted by
# rollup-plugin-visualizer on every `vite build`. Useful for
# ad-hoc audits (run `pnpm visualize` then open the file); never
# committed.
dist/bundle-stats.html

# Session 115 — Stryker mutation-testing artifacts. Run via
# `pnpm exec stryker run` (or `pnpm mutation`); writes HTML report
# under reports/mutation/ + a temp dir under node_modules. Ad-hoc
# analysis — never committed.
reports/
.stryker-tmp/

# Session 134 — diagnostic previews of the native CLR map (Chapter
# 13). Both are regenerated by `node scripts/render-clr-map-native.mjs`
# / `render-chapter13-preview.mjs` from `scripts/lib/clrMapHtml.mjs`,
# so committing them adds drift risk. The map itself ships as native
# HTML/SVG inside the book PDF — these files exist only for ad-hoc
# visual QA.
docs/guide/diagrams/clr-map-native.png
docs/guide/diagrams/clr-map-native.html
docs/guide/diagrams/clr-map-in-book.png
