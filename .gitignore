# TypeScript build artifacts. The root tsconfig has `noEmit: true`, but
# `tsc -b` walks project references and the referenced `tsconfig.node.json`
# (composite: true) can incidentally emit alongside `src/` TS sources when
# invoked from this directory. Keep the source tree clean.
*.tsbuildinfo
src/**/*.d.ts
!src/vite-env.d.ts
src/domain/types.js
src/domain/tokens.js
