node_modules
dist
coverage
# Transient stdout/stderr dumps from manual `vitest` / `tsc` runs (we
# captured these to a file during early sessions to work around
# Windows PowerShell quirks; they're never part of the build).
vitest-output.txt
tsc-output.txt
# Playwright e2e — `playwright-report` is the HTML report from the last
# run; `test-results` carries screenshots / videos / traces from failures.
playwright-report
test-results
.DS_Store
*.log
.vite
.env
.env.local
.idea
.vscode

# TypeScript build artifacts. The root tsconfig has `noEmit: true`, but
# `tsc -b` walks project references and the referenced `tsconfig.node.json`
# (composite: true) can incidentally emit alongside `src/` TS sources when
# invoked from this directory. Keep the source tree clean.
*.tsbuildinfo
src/**/*.d.ts
!src/vite-env.d.ts
src/domain/types.js
src/domain/tokens.js
