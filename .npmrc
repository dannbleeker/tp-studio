engine-strict=true
# Session 85 — pnpm 10.x build-script + install policy. Combined with
# `package.json#pnpm.onlyBuiltDependencies` + `ignoredBuiltDependencies`,
# these settings stop pnpm from regenerating `pnpm-workspace.yaml`'s
# `allowBuilds:` placeholder on every install — the root cause of the
# Session-80/81 CI `ERR_PNPM_IGNORED_BUILDS` dance.
#
# `confirm-modules-purge=false` — let pnpm install non-interactively
# without the "Aborted removal of modules directory due to no TTY" prompt
# from a stale `node_modules`. Same effect as setting `CI=true`, but
# captured here so contributors don't need to remember the env-var trick.
confirm-modules-purge=false
# `manage-package-manager-versions=true` — pnpm/corepack pin honoured
# automatically; no manual `corepack enable` step.
manage-package-manager-versions=true
