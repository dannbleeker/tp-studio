{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "scripts/*.{mjs,cjs}",
    "tests/**/*.test.{ts,tsx}",
    "src/**/*.stories.{ts,tsx}",
    "e2e/**/*.spec.ts",
    "stryker.mutation.config.mjs",
    "vitest.mutation.config.ts"
  ],
  "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}", "e2e/**/*.ts", "scripts/**/*.{mjs,cjs}"],
  "ignore": ["e2e/global.d.ts", "tests/stubs/virtual-pwa-register.ts"],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": ["tailwindcss"],
  "rules": {
    "files": "error",
    "dependencies": "warn",
    "unlisted": "warn",
    "binaries": "warn",
    "unresolved": "warn",
    "exports": "error",
    "types": "error",
    "duplicates": "error",
    "enumMembers": "error"
  }
}
