{
  "name": "tp-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.cjs",
    "postinstall": "node ./node_modules/simple-git-hooks/cli.js",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "prebuild": "node ./scripts/build-docs-bundle.mjs",
    "docs:bundle": "node ./scripts/build-docs-bundle.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:pin": "node ./scripts/pin-coverage-thresholds.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "check:bundle-size": "node ./scripts/check-bundle-size.mjs",
    "book": "node ./scripts/build-book-pdf.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "simple-git-hooks": {
    "pre-commit": "node ./node_modules/lint-staged/bin/lint-staged.js",
    "commit-msg": "node ./scripts/check-commit-msg.cjs $1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "node ./node_modules/@biomejs/biome/bin/biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,md,yml,yaml,css}": [
      "node ./node_modules/@biomejs/biome/bin/biome format --write --no-errors-on-unmatched"
    ]
  },
  "engines": {
    "node": ">=22.22.1",
    "pnpm": "^10.0.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "dompurify": "^3.4.2",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "micromark": "^4.0.2",
    "micromark-extension-gfm": "^3.0.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "svg2pdf.js": "^2.5.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.48.0",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@testing-library/react": "^16.0.1",
    "@types/dagre": "^0.7.54",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.4",
    "autoprefixer": "^10.5.0",
    "fast-check": "^3.23.2",
    "jsdom": "^25.0.1",
    "lint-staged": "^17.0.4",
    "marked": "^18.0.3",
    "postcss": "^8.5.14",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^8.4.7",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.4",
    "workbox-window": "^7.4.1"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@biomejs/biome", "simple-git-hooks"],
    "ignoredBuiltDependencies": ["core-js"]
  }
}
