{
  "name": "tp-studio",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "author": "Dann Bleeker Pedersen",
  "type": "module",
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.cjs",
    "postinstall": "node ./node_modules/simple-git-hooks/cli.js",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "prebuild": "node ./scripts/build-docs-bundle.mjs",
    "docs:bundle": "node ./scripts/build-docs-bundle.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:pin": "node ./scripts/pin-coverage-thresholds.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "knip": "knip",
    "verify": "pnpm lint && tsc --noEmit && pnpm knip && pnpm test && pnpm build",
    "mutation": "stryker run",
    "visualize": "vite build --mode analyze",
    "check:bundle-size": "node ./scripts/check-bundle-size.mjs",
    "book": "pnpm book:epub && pnpm book:pdf",
    "book:pdf": "node ./scripts/build-book-pdf.mjs",
    "book:epub": "node ./scripts/build-book-epub.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "simple-git-hooks": {
    "pre-commit": "node ./node_modules/lint-staged/bin/lint-staged.js",
    "commit-msg": "node ./scripts/check-commit-msg.cjs $1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "node ./node_modules/@biomejs/biome/bin/biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,md,yml,yaml,css}": [
      "node ./node_modules/@biomejs/biome/bin/biome format --write --no-errors-on-unmatched"
    ]
  },
  "engines": {
    "node": ">=22.22.1",
    "pnpm": "^10.0.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "dompurify": "^3.4.5",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "micromark": "^4.0.2",
    "micromark-extension-gfm": "^3.0.0",
    "nanoid": "^5.1.11",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "svg2pdf.js": "^2.7.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "marked": "^18.0.4",
    "pdf-lib": "^1.17.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-checker": "^0.14.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "workbox-window": "^7.4.1"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome",
      "simple-git-hooks"
    ],
    "ignoredBuiltDependencies": [
      "core-js"
    ]
  }
}
